# Copy this file to .env and edit it for your machine.

# Absolute or relative path on the host machine containing only .hdf5 playback files.
# Example macOS/Linux:
# DATASET_HOST_DIR=/Users/alice/datasets/dexmimicgen/playback_data
# Example relative to this repository:
# DATASET_HOST_DIR=./data/playback_data
DATASET_HOST_DIR=./dataset

# Producer tutorial defaults.
MAX_SAMPLES=1000
PRODUCER_INTERVAL_SECONDS=5
PLAYBACK_TIMEOUT_SECONDS=9000
KAFKA_CONNECT_TIMEOUT_SECONDS=600
VIDEO_SKIP=5
MUJOCO_GL=osmesa
MONITOR_PORT=8000
